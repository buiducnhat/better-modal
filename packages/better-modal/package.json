{
	"name": "@buiducnhat/better-modal",
	"description": "A small, headless React utility for declarative modal state management. Register modals once, open them from anywhere in your app, and await their results as Promises.",
	"version": "0.0.5",
	"keywords": [
		"modal",
		"react",
		"zustand"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/buiducnhat/better-modal",
		"directory": "packages/better-modal"
	},
	"author": {
		"url": "https://github.com/buiducnhat",
		"name": "Nhat Bui",
		"email": "nhaths4701@gmail.com"
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsdown"
	},
	"devDependencies": {
		"@better-modal/config": "workspace:*",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"react": "^19",
		"@types/react": "^19"
	},
	"dependencies": {
		"zustand": "^5"
	}
}
